// Stuti PWA — Prisma Schema
// Database: Supabase PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     String     @db.Text
  excerpt     String?
  type        PostType
  status      PostStatus
  mood        String?
  tags        String[]
  pillar      String?
  coverImage  String?
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model FitnessDay {
  id            String   @id @default(cuid())
  date          DateTime @unique
  dayNumber     Int
  worked        Boolean  @default(false)
  workoutType   String?
  durationMins  Int?
  energyBefore  Int?
  energyAfter   Int?
  waterLitres   Float?
  sleepHours    Float?
  notes         String?  @db.Text
  isPublic      Boolean  @default(false)
  mood          String?
  createdAt     DateTime @default(now())
}

model HealthMetric {
  id         String   @id @default(cuid())
  date       DateTime
  metricName String
  value      Float
  unit       String
  notes      String?
  createdAt  DateTime @default(now())
}

model ContentPlan {
  id        String        @id @default(cuid())
  date      DateTime
  title     String?
  type      String
  platform  String
  pillar    String?
  status    ContentStatus
  caption   String?       @db.Text
  notes     String?
  postId    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model JourneyConfig {
  id            String   @id @default("singleton")
  startDate     DateTime
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  totalDays     Int      @default(0)
  phase         Int      @default(1)
  note          String?
  updatedAt     DateTime @updatedAt
}

enum PostType {
  BLOG
  POEM
  JOURNAL
  ESSAY
  CSR
  SPORTS
  FITNESS_REFLECTION
}

enum PostStatus {
  DRAFT
  PUBLISHED
  PRIVATE
}

enum ContentStatus {
  IDEA
  DRAFTED
  RECORDED
  POSTED
  SKIPPED
}

model FinanceEntry {
  id          String          @id @default(cuid())
  date        DateTime
  type        FinanceType
  amount      Float
  category    FinanceCategory
  note        String?
  isRecurring Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  content   String   @db.Text
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  area        GoalArea
  status      GoalStatus @default(ACTIVE)
  targetDate  DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model HabitLog {
  id        String   @id @default(cuid())
  date      DateTime
  habit     String
  done      Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())

  @@unique([date, habit])
}

enum GoalArea {
  FITNESS
  CAREER
  CREATIVE
  HEALTH
  FINANCE
  PERSONAL
  LEARNING
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  DROPPED
}

enum FinanceType {
  INCOME
  EXPENSE
}

enum FinanceCategory {
  FOOD
  TRANSPORT
  EMI
  SAVINGS
  HEALTH
  UTILITIES
  PERSONAL
  WORK
  SALARY
  FREELANCE
  OTHER
}
